---
import { SITE } from '../../config';
const year = new Date().getFullYear();

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/tags', label: 'Tags' },
];

const resourceLinks = [
  { href: '/rss.xml', label: 'RSS Feed' },
  { href: '/search-index.json', label: 'Search Index' },
];
---

<footer class="mt-auto" style="background: var(--color-surface);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
      <!-- Brand column -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-3">
          <span class="w-8 h-8 rounded-lg flex items-center justify-center text-white text-sm font-bold" style="background: var(--color-accent);">{SITE.logoLetter}</span>
          <span class="font-bold text-lg" style="color: var(--color-text-primary);">{SITE.name}</span>
        </a>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
          Tutorials, guides, and opinions on web development, CSS, TypeScript, and the modern web.
        </p>
      </div>

      <!-- Navigation column -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-muted);">Navigation</h3>
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm hover:opacity-80 transition-opacity"
                style="color: var(--color-text-secondary);"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources column -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-muted);">Resources</h3>
        <ul class="space-y-2">
          {resourceLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm hover:opacity-80 transition-opacity"
                style="color: var(--color-text-secondary);"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6" style="border-top: 1px solid var(--color-border);">
      <p class="text-sm text-center" style="color: var(--color-text-muted);">
        &copy; {year} {SITE.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
