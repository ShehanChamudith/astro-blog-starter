---
import PostCard from '../blog/PostCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h2 class="text-2xl font-bold" style="color: var(--color-text-primary);">Most Popular</h2>
      <p class="mt-1 text-sm" style="color: var(--color-text-muted);">Articles readers love most</p>
    </div>
    <a href="/blog" class="text-sm font-medium hover:opacity-70 transition-opacity" style="color: var(--color-accent);">
      View all →
    </a>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</section>
