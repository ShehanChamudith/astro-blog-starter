---
import type { CollectionEntry } from 'astro:content';

interface Props {
  author: CollectionEntry<'authors'>;
}

const { author } = Astro.props;
const { name, bio, twitter, github, website } = author.data;
const initials = name.split(' ').map((n) => n[0]).join('').slice(0, 2).toUpperCase();
---

<div class="flex gap-4 sm:gap-6 p-5 sm:p-6 rounded-2xl" style="background: var(--color-surface); border: 1px solid var(--color-border);">
  <!-- Avatar placeholder -->
  <div
    class="flex-shrink-0 w-14 h-14 rounded-full flex items-center justify-center text-lg font-bold text-white"
    style="background: var(--color-accent);"
    aria-hidden="true"
  >
    {initials}
  </div>

  <div class="flex-1 min-w-0">
    <p class="text-xs font-medium uppercase tracking-wide mb-1" style="color: var(--color-text-muted);">Written by</p>
    <h3 class="font-bold text-lg" style="color: var(--color-text-primary);">{name}</h3>
    <p class="mt-1 text-sm leading-relaxed" style="color: var(--color-text-secondary);">{bio}</p>

    <div class="mt-3 flex flex-wrap gap-3">
      {twitter && (
        <a
          href={`https://twitter.com/${twitter}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-medium flex items-center gap-1.5 hover:opacity-70 transition-opacity"
          style="color: var(--color-accent);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.629zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          @{twitter}
        </a>
      )}
      {github && (
        <a
          href={`https://github.com/${github}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-medium flex items-center gap-1.5 hover:opacity-70 transition-opacity"
          style="color: var(--color-accent);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          {github}
        </a>
      )}
      {website && (
        <a
          href={website}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-medium hover:opacity-70 transition-opacity"
          style="color: var(--color-accent);"
        >
          Website →
        </a>
      )}
    </div>
  </div>
</div>
