---
import CategoryBadge from './CategoryBadge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  author: CollectionEntry<'authors'>;
  readingTimeMin: number;
}

const { post, author, readingTimeMin } = Astro.props;
const { publishDate, category } = post.data;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<div class="flex flex-wrap items-center gap-3">
  <CategoryBadge category={category} />

  <div class="flex items-center gap-2 text-sm" style="color: var(--color-text-muted);">
    <span class="font-medium" style="color: var(--color-text-secondary);">{author.data.name}</span>
    <span aria-hidden="true">&middot;</span>
    <time datetime={publishDate.toISOString()}>{formattedDate}</time>
    <span aria-hidden="true">&middot;</span>
    <span>{readingTimeMin} min read</span>
  </div>
</div>
