---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth <= 3);
---

<nav id="toc" aria-label="Table of contents" class="sticky top-24">
  <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-muted);">
    On this page
  </p>
  <ol class="space-y-1 text-sm max-h-[70vh] overflow-y-auto pr-1">
    {filtered.map((heading) => (
      <li>
        <a
          href={`#${heading.slug}`}
          data-toc-link={heading.slug}
          class={`block py-1 transition-colors hover:opacity-80 ${heading.depth === 3 ? 'pl-4' : ''}`}
          style="color: var(--color-text-secondary);"
        >
          {heading.text}
        </a>
      </li>
    ))}
  </ol>
</nav>

<script>
  function initTOC() {
    const links = document.querySelectorAll('[data-toc-link]');
    if (!links.length) return;

    const headingEls: HTMLElement[] = [];
    links.forEach((link) => {
      const slug = (link as HTMLElement).dataset.tocLink!;
      const el = document.getElementById(slug);
      if (el) headingEls.push(el);
    });

    let activeSlug = '';

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            activeSlug = entry.target.id;
          }
        }
        links.forEach((link) => {
          const a = link as HTMLElement;
          const isActive = a.dataset.tocLink === activeSlug;
          a.style.color = isActive ? 'var(--color-accent)' : 'var(--color-text-secondary)';
          a.style.fontWeight = isActive ? '600' : '400';
        });
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );

    headingEls.forEach((el) => observer.observe(el));
  }

  initTOC();
  document.addEventListener('astro:after-swap', initTOC);
</script>
