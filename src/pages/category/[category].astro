---
import PageLayout from '../../layouts/PageLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { sortByDate } from '../../utils/sort-posts';
import { slugify } from '../../utils/slugify';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => !data.draft);
  const categories = [...new Set(allPosts.map((p) => p.data.category))];

  return categories.map((category) => ({
    params: { category: slugify(category) },
    props: {
      category,
      posts: sortByDate(allPosts.filter((p) => p.data.category === category)),
    },
  }));
}

interface Props {
  category: string;
  posts: CollectionEntry<'blog'>[];
}

const { category, posts } = Astro.props;
---

<PageLayout
  title={`${category} Articles`}
  description={`Browse all articles in the ${category} category.`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="mb-10">
      <a href="/blog" class="text-sm font-medium flex items-center gap-1 mb-4 hover:opacity-70 transition-opacity" style="color: var(--color-text-muted);">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        All articles
      </a>
      <div class="flex items-center gap-3">
        <span class="text-3xl">📂</span>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: var(--color-accent);">Category</p>
          <h1 class="text-3xl sm:text-4xl font-bold" style="color: var(--color-text-primary);">{category}</h1>
        </div>
      </div>
      <p class="mt-3 text-lg" style="color: var(--color-text-secondary);">
        {posts.length} article{posts.length !== 1 ? 's' : ''}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</PageLayout>
