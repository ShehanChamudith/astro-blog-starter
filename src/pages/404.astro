---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="404 — Page Not Found" noindex={true}>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="text-8xl font-black" style="color: var(--color-accent);">404</p>
    <h1 class="mt-4 text-3xl font-bold" style="color: var(--color-text-primary);">Page not found</h1>
    <p class="mt-4 text-lg" style="color: var(--color-text-secondary);">
      Sorry, we couldn't find the page you're looking for.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/"
        class="px-6 py-3 rounded-xl text-sm font-semibold text-white transition-opacity hover:opacity-90"
        style="background: var(--color-accent);"
      >
        Back to home
      </a>
      <a
        href="/blog"
        class="px-6 py-3 rounded-xl text-sm font-semibold border transition-colors hover:opacity-80"
        style="border-color: var(--color-border); color: var(--color-text-secondary);"
      >
        Browse articles
      </a>
    </div>
  </div>
</PageLayout>
