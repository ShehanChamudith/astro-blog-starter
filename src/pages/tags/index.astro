---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { slugify } from '../../utils/slugify';

const allPosts = await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => !data.draft);

const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<PageLayout title="Tags" description="Browse all article tags.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold" style="color: var(--color-text-primary);">Tags</h1>
      <p class="mt-2 text-lg" style="color: var(--color-text-secondary);">
        {tags.length} tag{tags.length !== 1 ? 's' : ''} across all articles
      </p>
    </div>

    <div class="flex flex-wrap gap-3">
      {tags.map(([tag, count]) => (
        <a
          href={`/tags/${slugify(tag)}`}
          class="group flex items-center gap-2 px-4 py-2 rounded-full border text-sm font-medium transition-all hover:shadow-md"
          style="background: var(--color-surface); border-color: var(--color-border); color: var(--color-text-secondary);"
        >
          <span class="group-hover:opacity-80">#{tag}</span>
          <span
            class="w-5 h-5 flex items-center justify-center rounded-full text-xs font-bold text-white"
            style="background: var(--color-accent);"
          >
            {count}
          </span>
        </a>
      ))}
    </div>
  </div>
</PageLayout>
