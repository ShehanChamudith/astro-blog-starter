---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, getEntry, render, type CollectionEntry } from 'astro:content';
import { sortByDate, getRelatedPosts } from '../../utils/sort-posts';
import { readingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const author = await getEntry('authors', post.data.author.id);
const { Content, headings } = await render(post);

const allPosts = await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => !data.draft);
const relatedPosts = getRelatedPosts(post, sortByDate(allPosts));
const minutes = readingTime(post.body ?? '');
---

<BlogLayout
  post={post}
  author={author!}
  headings={headings}
  relatedPosts={relatedPosts}
  readingTimeMin={minutes}
>
  <Content />
</BlogLayout>
