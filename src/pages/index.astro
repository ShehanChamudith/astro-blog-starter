---
import PageLayout from '../layouts/PageLayout.astro';
import FeaturedPost from '../components/home/FeaturedPost.astro';
import PopularArticles from '../components/home/PopularArticles.astro';
import LatestArticles from '../components/home/LatestArticles.astro';
import SearchBox from '../components/search/SearchBox.astro';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import { sortByDate, sortByPopularity } from '../utils/sort-posts';

type BlogPost = CollectionEntry<'blog'>;

const allPosts = await getCollection('blog', ({ data }: BlogPost) => !data.draft);

const featuredPost = sortByDate(allPosts).find((p: BlogPost) => p.data.featured) ?? sortByDate(allPosts)[0];
const featuredAuthor = await getEntry('authors', featuredPost.data.author.id);

const popular = sortByPopularity(allPosts.filter((p: BlogPost) => p.id !== featuredPost.id)).slice(0, 6);
const latest = sortByDate(allPosts.filter((p: BlogPost) => p.id !== featuredPost.id)).slice(0, 6);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://yourdomain.com';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'DevBlog',
    url: siteUrl,
    potentialAction: {
      '@type': 'SearchAction',
      target: `${siteUrl}/blog?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'DevBlog',
    url: siteUrl,
    logo: `${siteUrl}/favicon.svg`,
  },
];
---

<PageLayout title="DevBlog — Web Development Articles" description="Articles about web development, modern tooling, CSS, TypeScript, and the open web." jsonLd={jsonLd}>

  <!-- Site hero / search -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-14 pb-10 text-center">
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight" style="color: var(--color-text-primary);">
      Insights for the<br class="hidden sm:block" />
      <span style="color: var(--color-accent);"> modern web</span>
    </h1>
    <p class="mt-4 text-lg max-w-xl mx-auto" style="color: var(--color-text-secondary);">
      Tutorials, guides, and opinions on web development, CSS, TypeScript, and the open web.
    </p>
    <div class="mt-8 max-w-xl mx-auto">
      <SearchBox instanceId="home" placeholder="Search articles, tags, categories..." />
    </div>
  </div>

  <!-- Featured -->
  <FeaturedPost post={featuredPost} author={featuredAuthor!} />

  <!-- Popular articles -->
  <PopularArticles posts={popular} />

  <!-- Latest articles -->
  <LatestArticles posts={latest} />

</PageLayout>
